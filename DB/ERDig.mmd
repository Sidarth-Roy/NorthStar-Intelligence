    %% --- RELATIONSHIPS ---
    CATEGORIES ||--o{ PRODUCTS : "contains"
    CUSTOMERS ||--o{ ORDERS : "places"
    EMPLOYEES ||--o{ ORDERS : "handles"
    EMPLOYEES |o--o| EMPLOYEES : "reports to"
    SHIPPERS ||--o{ ORDERS : "delivers"
    ORDERS ||--o{ ORDER_DETAILS : "consists of"
    PRODUCTS ||--o{ ORDER_DETAILS : "included in"

    CATEGORIES {
        uint categoryID PK
        string categoryName
        string description
    }

    CUSTOMERS {
        string customerID PK
        string companyName
        string contactName
        string contactTitle
        string city
        string country
    }

    EMPLOYEES {
        uint employeeID PK
        string employeeName
        string title
        string city
        string country
        uint reportsTo FK
    }

    SHIPPERS {
        uint shipperID PK
        string companyName
    }

    PRODUCTS {
        uint productID PK
        string productName
        string quantityPerUnit
        float unitPrice
        int discontinued
        uint categoryID FK
    }

    ORDERS {
        uint orderID PK
        string customerID FK
        uint employeeID FK
        uint shipperID FK
        datetime orderDate
        datetime requiredDate
        datetime shippedDate
        float freight
    }

    ORDER_DETAILS {
        uint orderID PK
        uint productID PK
        float unitPrice
        int quantity
        float discount
    }



%% To understand an Entity-Relationship Diagram (ERD), you should read it like a "Map of Truth" for your data. Think of it in three layers: Boxes (The People/Things), Lines (The Relationships), and Keys (The Connections).
%% Here is how to decode the specific symbols and logic in your diagram:
%% 1. The Symbols (Crow's Foot Notation)
%% The lines tell you "How many" of one thing can relate to another.

%% * ||--o{ (One-to-Many): Read this as "One [Left] has Zero or Many [Right]".
%% * Example: One Category contains many Products.
%% * |o--o| (Optional One-to-One): Read this as "One [Left] might have One [Right]".
%% * Example: One Employee reports to one Manager (or none if they are the CEO).

%% 2. The Relationship Logic (Business Rules)
%% Think of these as sentences:

%% * CUSTOMERS to ORDERS: A customer is a permanent record; an order is a transaction linked to them. You can have a customer who hasn't bought anything yet (o{).
%% * ORDERS to ORDER_DETAILS: This is the "Receipt" logic. One Order ID (e.g., #101) is broken down into multiple lines (e.g., 2 Apples, 1 Bread) in the Order Details table.
%% * EMPLOYEES to EMPLOYEES: This is a Self-Join. It means the table has a column (reportsTo) that points back to another ID in the same table.

%% 3. The Keys (The "Hooks")

%% * PK (Primary Key): The unique ID for that specific box. No two rows can have the same PK.
%% * FK (Foreign Key): A "pointer." If PRODUCTS has a categoryID FK, it’s just a "hook" reaching back to the CATEGORIES table to grab that category's details.

%% 4. How to Read the "Flow"
%% If you want to find out "Which country bought the most apples?", you follow the path:

%%    1. Product (Find "Apple") →
%%    2. Order Details (Find all sales of that ProductID) →
%%    3. Orders (Link those sales to specific OrderIDs) →
%%    4. Customers (Link those orders to the Customer's country).


